# How many unique rodent species were captured in this study?
num_rodents <- rodents_only_df %>% select(genus, species) %>% reframe(unique(species)) %>% count() %>%
rename("No. of Unique Rodent Species" = n)
num_rodents
# How often were each of them observed?
num_each_species <- rodents_only_df %>%
mutate(genus_species = paste(genus,species)) %>%
