num_each_species
rodent_abundance_plot <- rodents_only_df %>%
filter(plot_type == "Control") %>%
mutate(genus_species = paste(genus,species)) %>%
group_by(year, genus_species) %>% mutate(count = 1) %>%
mutate(species_count = sum(count)) %>%
select(year, genus_species, species_count) %>%
distinct(genus_species, .keep_all = TRUE) %>%
ggplot(aes(x = year, y = species_count, colour = as.factor(year))) +
geom_point(size = 0.5) +
labs(title = "Count of Each Rodent Control By Year", x = "Year",
y = "Count of Each Species Each Year") +
facet_wrap(~ genus_species) +
theme(plot.title = element_text(size = 11),
plot.margin = margin(t = 30, r = 10, b = 10, l = 10),
axis.text.x = element_text(angle = 45,vjust=1, hjust=1))
rodent_abundance_plot
rodent_mass_spec_df <- rodents_only_df %>%
filter(plot_type == "Control", !is.na(weight)) %>%
mutate(genus_species = paste(genus,species)) %>%
select(year, genus_species, weight) %>%
group_by(year, genus_species) %>% mutate(avg_mass = mean(weight)) %>%
distinct(genus_species, .keep_all = TRUE)
rodent_mass_box <- rodent_mass_spec_df %>%
ggplot(aes(x = genus_species, y = avg_mass)) + geom_boxplot() +
labs(title = "To Examine the Variation in Average Mass of Each Rodent Control",
x = "Species of Rodents in the Control Group", y = "Average Mass") +
theme(plot.title = element_text(size = 11),
plot.margin = margin(t = 30, r = 10, b = 10, l = 10),
axis.text.x = element_text(angle = 45,vjust=1, hjust=1))
rodent_mass_plot <- rodent_mass_spec_df %>%
ggplot(aes(x = year, y = avg_mass)) + geom_point(size = 0.5) +
labs(title = "To Examine the Average Mass of Each Rodent Control Each Year",
x = "Year", y = "Average Mass") + facet_wrap(~ genus_species) +
theme(plot.title = element_text(size = 11),
plot.margin = margin(t = 30, r = 10, b = 10, l = 10),
axis.text.x = element_text(angle = 45,vjust=1, hjust=1))
rodent_mass_plot
rodent_mass_box
